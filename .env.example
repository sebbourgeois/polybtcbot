# ── Auth (required for LIVE trading only) ────────────────────────────
# BOT_PRIVATE_KEY=0xYOUR_POLYGON_WALLET_PRIVATE_KEY

# ── Mode ─────────────────────────────────────────────────────────────
BOT_PAPER_MODE=true
BOT_LOG_LEVEL=INFO

# ── Trading parameters ───────────────────────────────────────────────
BOT_BANKROLL=100.0
BOT_MIN_SIGNAL_STRENGTH=0.30
BOT_MIN_EDGE=0.05
BOT_BTC_5M_VOLATILITY=30.0
BOT_LIMIT_SLIPPAGE=0.02

# ── Risk limits ──────────────────────────────────────────────────────
BOT_MAX_POSITION_USD=25.0
BOT_MIN_POSITION_USD=2.0
BOT_MAX_DAILY_LOSS_USD=50.0
BOT_MAX_CONSECUTIVE_LOSSES=5
BOT_MAX_PRICE_TO_PAY=0.65
BOT_HEDGE_TRIGGER=0.15

# ── Timing ───────────────────────────────────────────────────────────
BOT_DISCOVERY_INTERVAL_SEC=30.0
BOT_WARMUP_SEC=30.0
BOT_COOLDOWN_SEC=60.0
BOT_RISK_CHECK_SEC=2.0

# ── Web dashboard ────────────────────────────────────────────────────
# BOT_HOST=0.0.0.0
# BOT_PORT=8500

# ── Storage ──────────────────────────────────────────────────────────
BOT_DB_PATH=./btcbot.db

# ── API endpoints (defaults are fine) ────────────────────────────────
# BOT_CLOB_API=https://clob.polymarket.com
# BOT_GAMMA_API=https://gamma-api.polymarket.com
# BOT_CLOB_WS=wss://ws-subscriptions-clob.polymarket.com/ws/market
# BOT_BINANCE_WS=wss://stream.binance.com:9443/ws/btcusdt@trade
